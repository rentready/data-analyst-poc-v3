# Example Streamlit Secrets Configuration
# Copy this file to .streamlit/secrets.toml and fill in your values
# NEVER commit .streamlit/secrets.toml to version control!

# Knowledge Base Configuration
# Vector Store ID for File Search Tool (create using create_vector_store.py script)
vector_store_id = ""  # Example: "vs_abc123..."

# Azure AI Foundry Configuration
[azure_ai_foundry]
proj_endpoint = "https://your-project.cognitiveservices.azure.com/"
model_deployment_name = "gpt-4o"  # or your model deployment name

# Environment Variables for Azure Authentication
[env]
AZURE_CLIENT_ID = "your-app-client-id"
AZURE_CLIENT_SECRET = "your-app-client-secret"
AZURE_TENANT_ID = "your-tenant-id"

# OpenAI Configuration
[open_ai]
api_key = "sk-..."  # Your OpenAI API key
model = "gpt-4o"  # or gpt-4-turbo, gpt-4, etc.
base_url = ""  # Optional: Custom API endpoint

# MCP (Model Context Protocol) Configuration
[mcp]
mcp_client_id = "your-mcp-client-id"
mcp_client_secret = "your-mcp-client-secret"
mcp_server_url = "https://your-mcp-server.azurewebsites.net"
allowed_tools = [
    "mcp_rentready-sandbox_find_accounts",
    "mcp_rentready-sandbox_find_invoices",
    "mcp_rentready-sandbox_find_job_profiles",
    "mcp_rentready-sandbox_find_work_orders",
    "mcp_rentready-sandbox_execute_sql",
    # Add more allowed tools as needed
]

# Glossary Agent Instructions
[glossary]
instructions = """You are a business glossary expert. Provide clear definitions of business terms, 
table names, field names, and relationships in the RentReady system.

When asked about business concepts:
1. Provide the official business definition
2. Explain the technical implementation (tables, fields)
3. Mention related concepts
4. Use File Search tool to find information in knowledge base documents

Keep answers concise and practical."""

# Application Settings
[app]
max_tokens = 4000
temperature = 0.1

